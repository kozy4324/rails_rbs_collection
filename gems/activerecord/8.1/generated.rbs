    extend ActiveSupport::Concern

    module ClassMethods
      @_store_accessors_module: untyped

      def store: (untyped store_attribute, ?::Hash[untyped, untyped] options) -> untyped

      def store_accessor: (untyped store_attribute, *untyped keys, ?prefix: untyped?, ?suffix: untyped?) -> (false | nil | untyped)

