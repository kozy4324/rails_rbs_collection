module ActiveRecord
  module Batches
    class BatchEnumerator
      @of: untyped

      @relation: untyped

      @start: untyped

      @finish: untyped

      @cursor: untyped

      @order: untyped

      @use_ranges: untyped

      include Enumerable

      def initialize: (relation: untyped, cursor: untyped, ?of: ::Integer, ?start: untyped?, ?finish: untyped?, ?order: ::Symbol, ?use_ranges: untyped?) -> void

      # The primary key value from which the BatchEnumerator starts, inclusive of the value.
      attr_reader start: untyped

      # The primary key value at which the BatchEnumerator ends, inclusive of the value.
      attr_reader finish: untyped

      # The relation from which the BatchEnumerator yields batches.
      attr_reader relation: untyped

      # The size of the batches yielded by the BatchEnumerator.
      def batch_size: () -> untyped

      # Looping through a collection of records from the database (using the
      # +all+ method, for example) is very inefficient since it will try to
      # instantiate all the objects at once.
      #
      # In that case, batch processing methods allow you to work with the
      # records in batches, thereby greatly reducing memory consumption.
      #
      #   Person.in_batches.each_record do |person|
      #     person.do_awesome_stuff
      #   end
      #
      #   Person.where("age > 21").in_batches(of: 10).each_record do |person|
      #     person.party_all_night!
      #   end
      #
      # If you do not provide a block to #each_record, it will return an Enumerator
      # for chaining with other methods:
      #
      #   Person.in_batches.each_record.with_index do |person, index|
      #     person.award_trophy(index + 1)
      #   end
      def each_record: () ?{ (?) -> untyped } -> untyped

      # Deletes records in batches. Returns the total number of rows affected.
      #
      #   Person.in_batches.delete_all
      #
      # See Relation#delete_all for details of how each batch is deleted.
      def delete_all: () -> untyped

      # Updates records in batches. Returns the total number of rows affected.
      #
      #   Person.in_batches.update_all("age = age + 1")
      #
      # See Relation#update_all for details of how each batch is updated.
      def update_all: (untyped updates) -> untyped

      # Touches records in batches. Returns the total number of rows affected.
      #
      #   Person.in_batches.touch_all
