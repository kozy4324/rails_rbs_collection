    def readonly!: () -> untyped

    def connection_handler: () -> untyped

    # Returns the attributes of the record as a nicely formatted string.
    #
    #   Post.first.inspect
    #   #=> "#<Post id: 1, title: "Hello, World!", published_at: "2023-10-23 14:28:11 +0000">"
