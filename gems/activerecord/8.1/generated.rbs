      # check <tt>collection.length.zero?</tt>.
      def empty?: () -> untyped

      # Replace this collection with +other_array+. This will perform a diff
      # and delete/add only records that have changed.
      def replace: (untyped other_array) -> untyped

      def include?: (untyped record) -> (false | untyped)

      def load_target: () -> untyped

      def add_to_target: (untyped record, ?skip_callbacks: bool, ?replace: bool) { (?) -> untyped } -> untyped

      def target=: (untyped record) -> untyped

      def scope: () -> untyped

      def null_scope?: () -> untyped

      def find_from_target?: () -> untyped

      def collection?: () -> true

      private

      def transaction: () { (?) -> untyped } -> untyped

