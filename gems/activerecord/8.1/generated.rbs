      # Returns an array of the values of the first column in a select:
      #   select_values("SELECT id FROM companies LIMIT 3") => [1,2,3]
      def select_values: (untyped arel, ?untyped? name, ?untyped binds) -> untyped

      # Returns an array of arrays containing the field values.
      # Order is the same as that returned by +columns+.
      def select_rows: (untyped arel, ?untyped? name, ?untyped binds, ?async: bool) -> untyped

      def query_value: (*untyped, **untyped) ?{ (?) -> untyped } -> untyped

      def query_values: (*untyped, **untyped) ?{ (?) -> untyped } -> untyped

      def query: (untyped sql, ?untyped? name, ?allow_retry: bool, ?materialize_transactions: bool) -> untyped

      # Determines whether the SQL statement is a write query.
      def write_query?: (untyped sql) -> untyped

      # Executes the SQL statement in the context of this connection and returns
      # the raw result from the connection adapter.
      #
      # Setting +allow_retry+ to true causes the db to reconnect and retry
      # executing the SQL statement in case of a connection-related exception.
      # This option should only be enabled for known idempotent queries.
      #
      # Note: the query is assumed to have side effects and the query cache
      # will be cleared. If the query is read-only, consider using #select_all
      # instead.
      #
