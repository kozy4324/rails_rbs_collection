module ActiveRecord
  module ConnectionAdapters
    module PostgreSQL
      module OID
        class Range < Type::Value
          @subtype: untyped

          @type: untyped

          attr_reader subtype: untyped

          attr_reader type: untyped

          def initialize: (untyped subtype, ?::Symbol type) -> void

          def type_cast_for_schema: (untyped value) -> untyped

          def cast_value: (untyped value) -> (nil | untyped)

          def serialize: (untyped value) -> untyped

          def ==: (untyped other) -> untyped

          def map: (untyped value) { (untyped) -> untyped } -> untyped

          def force_equality?: (untyped value) -> untyped

          private

          def type_cast_single: (untyped value) -> untyped

          def type_cast_single_for_database: (untyped value) -> untyped

          def extract_bounds: (untyped value) -> { from: untyped, to: untyped, exclude_start: untyped, exclude_end: untyped }

          INFINITE_FLOAT_RANGE: ::Range[untyped]

          def sanitize_bounds: (untyped from, untyped to) -> ::Array[untyped]

          # When formatting the bound values of range types, PostgreSQL quotes
          # the bound value using double-quotes in certain conditions. Within
          # a double-quoted string, literal " and \ characters are themselves
          # escaped. In input, PostgreSQL accepts multiple escape styles for "
          # (either \" or "") but in output always uses "".
          # See:
          # * https://www.postgresql.org/docs/current/rangetypes.html#RANGETYPES-IO
          # * https://www.postgresql.org/docs/current/rowtypes.html#ROWTYPES-IO-SYNTAX
          def unquote: (untyped value) -> untyped

          def infinity: (?negative: bool) -> untyped

          def infinity?: (untyped value) -> untyped
        end
      end
    end
  end
end
