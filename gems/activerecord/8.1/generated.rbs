      def supports_explain?: () -> true

      def supports_lazy_transactions?: () -> true

      def supports_deferrable_constraints?: () -> true

      def disable_referential_integrity: () { () -> untyped } -> untyped

      def check_all_foreign_keys_valid!: () -> untyped

      def primary_keys: (untyped table_name) -> untyped

      def remove_index: (untyped table_name, ?untyped? column_name, **untyped options) -> (nil | untyped)

