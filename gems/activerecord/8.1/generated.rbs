      @owner: untyped

      @reflection: untyped

      @disable_joins: untyped

      @skip_strict_loading: untyped

      @target: untyped

      @loaded: untyped

      @stale_state: untyped

      @association_scope: untyped

      attr_accessor owner: untyped

      attr_reader reflection: untyped

      attr_reader disable_joins: untyped

      def initialize: (untyped owner, untyped reflection) -> void

      def target: () -> untyped

      # Resets the \loaded flag to +false+ and sets the \target to +nil+.
      def reset: () -> untyped

      def reset_negative_cache: () -> (untyped | nil)

      # Reloads the \target and returns +self+ on success.
      # The QueryCache is cleared if +force+ is true.
      def reload: (?bool force) -> untyped

      # Has the \target been already \loaded?
      def loaded?: () -> untyped

      # Asserts the \target has been loaded setting the \loaded flag to +true+.
      def loaded!: () -> untyped

