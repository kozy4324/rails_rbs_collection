      def each_key: () { (?) -> untyped } -> untyped

      def keys: () -> untyped

      def ==: (untyped other) -> untyped

      def key?: (untyped column) -> untyped

      def fetch: (untyped column) ?{ () -> untyped } -> untyped

      def []: (untyped column) -> (untyped | nil)

      def to_h: () -> untyped

      alias to_hash to_h
