    attr_reader rows: untyped

    attr_reader affected_rows: untyped

    def self.empty: (?async: bool, ?affected_rows: untyped?) -> untyped

    def initialize: (untyped columns, untyped rows, ?untyped? column_types, ?affected_rows: untyped?) -> void

