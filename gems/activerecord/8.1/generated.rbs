      attr_reader db_config: untyped

      attr_reader max_connections: untyped

      attr_reader min_connections: untyped

      attr_reader max_age: untyped

      attr_reader keepalive: untyped

      attr_reader reaper: untyped

      attr_reader pool_config: untyped

      attr_reader async_executor: untyped

