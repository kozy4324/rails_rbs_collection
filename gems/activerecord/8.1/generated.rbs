    private

    def model_class=: (untyped class_name) -> (untyped | untyped | nil)

    def ignored_fixtures=: (untyped base) -> untyped

    def read_fixture_files: (untyped path) -> untyped

    def default_fixture_model_class: () -> untyped
  end

