        def build_change_column_default_definition: (untyped table_name, untyped column_name, untyped default_or_changes) -> (nil | untyped)

        def change_column_null: (untyped table_name, untyped column_name, untyped null, ?untyped? default) -> untyped

        # Adds comment for given table column or drops it if +comment+ is a +nil+
        def change_column_comment: (untyped table_name, untyped column_name, untyped comment_or_changes) -> untyped

        # Adds comment for given table or drops it if +comment+ is a +nil+
        def change_table_comment: (untyped table_name, untyped comment_or_changes) -> untyped

        # Renames a column in a table.
        def rename_column: (untyped table_name, untyped column_name, untyped new_column_name) -> untyped

        def add_index: (untyped table_name, untyped column_name, **untyped options) -> untyped

        def build_create_index_definition: (untyped table_name, untyped column_name, **untyped options) -> untyped

        def remove_index: (untyped table_name, ?untyped? column_name, **untyped options) -> (nil | untyped)

