module ActiveRecord
  # Statement cache is used to cache a single statement in order to avoid creating the AST again.
  # Initializing the cache is done by passing the statement in the create block:
  #
  #   cache = StatementCache.create(ClothingItem.lease_connection) do |params|
  #     Book.where(name: "my book").where("author_id > 3")
  #   end
  #
  # The cached statement is executed by using the
  # {connection.execute}[rdoc-ref:ConnectionAdapters::DatabaseStatements#execute] method:
  #
  #   cache.execute([], ClothingItem.lease_connection)
  #
  # The relation returned by the block is cached, and for each
  # {execute}[rdoc-ref:ConnectionAdapters::DatabaseStatements#execute]
  # call the cached relation gets duped. Database is queried when +to_a+ is called on the relation.
  #
  # If you want to cache the statement without the values you can use the +bind+ method of the
  # block parameter.
  #
  #   cache = StatementCache.create(ClothingItem.lease_connection) do |params|
  #     Book.where(name: params.bind)
  #   end
  #
  # And pass the bind values as the first argument of +execute+ call.
  #
  #   cache.execute(["my book"], ClothingItem.lease_connection)
  class StatementCache
    @query_builder: untyped

    @bind_map: untyped

    @model: untyped

    class Substitute
    end

    class Query
      @sql: untyped

      @retryable: untyped

      attr_reader retryable: untyped

      def initialize: (untyped sql, retryable: untyped) -> void

      def sql_for: (untyped binds, untyped connection) -> untyped
    end

    class PartialQuery < Query
      @values: untyped

      @indexes: untyped

      @retryable: untyped

      def initialize: (untyped values, retryable: untyped) -> void

      def sql_for: (untyped binds, untyped connection) -> untyped
    end

    class PartialQueryCollector
      @parts: untyped

      @binds: untyped

      attr_accessor preparable: untyped

      attr_accessor retryable: untyped

      def initialize: () -> void

      def <<: (untyped str) -> self

      def add_bind: (untyped obj) { (?) -> untyped } -> self

      def add_binds: (untyped binds, ?untyped? proc_for_binds) { (?) -> untyped } -> self

      def value: () -> ::Array[untyped]
    end

    def self.query: (*untyped, **untyped) ?{ (?) -> untyped } -> untyped

    def self.partial_query: (*untyped, **untyped) ?{ (?) -> untyped } -> untyped

    def self.partial_query_collector: () -> untyped

    class Params
      def bind: () -> untyped
    end

    class BindMap
      @indexes: untyped

      @bound_attributes: untyped

      def initialize: (untyped bound_attributes) -> void

      def bind: (untyped values) -> untyped
    end

    def self.create: (untyped connection, ?untyped? callable) { (?) -> untyped } -> untyped

    def initialize: (untyped query_builder, untyped bind_map, untyped model) -> void

    def execute: (untyped params, untyped connection, ?async: bool) { (?) -> untyped } -> untyped

    def self.unsupported_value?: (untyped value) -> untyped
  end
