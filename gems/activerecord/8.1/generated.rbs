      def insert_fixture: (untyped fixture, untyped table_name) -> untyped

      def insert_fixtures_set: (untyped fixture_set, ?untyped tables_to_delete) -> untyped

      def empty_insert_statement_value: (?untyped? primary_key) -> "DEFAULT VALUES"

      # Fixture value is quoted by Arel, however scalar values
      # are not quotable. In this case we want to convert
      # the column value to YAML.
      def with_yaml_fallback: (untyped value) -> untyped

      # This is a safe default, even if not high precision on all databases
      HIGH_PRECISION_CURRENT_TIMESTAMP: untyped

      # Returns an Arel SQL literal for the CURRENT_TIMESTAMP for usage with
      # arbitrary precision date/time columns.
      #
      # Adapters supporting datetime with precision should override this to
      # provide as much precision as is available.
      def high_precision_current_timestamp: () -> untyped

      # Same as raw_execute but returns an ActiveRecord::Result object.
      def raw_exec_query: (*untyped, **untyped) ?{ (?) -> untyped } -> untyped

      # Execute a query and returns an ActiveRecord::Result
      def internal_exec_query: (*untyped, **untyped) ?{ (?) -> untyped } -> untyped

      def default_insert_value: (untyped column) -> untyped

      private

      DEFAULT_INSERT_VALUE: untyped

      # Lowest level way to execute a query. Doesn't check for illegal writes, doesn't annotate queries, yields a native result object.
      def raw_execute: (untyped sql, ?untyped? name, ?untyped binds, ?prepare: bool, ?async: bool, ?allow_retry: bool, ?materialize_transactions: bool, ?batch: bool) -> untyped

      def perform_query: (untyped raw_connection, untyped sql, untyped binds, untyped type_casted_binds, prepare: untyped, notification_payload: untyped, batch: untyped) -> untyped

      def handle_warnings: (untyped raw_result, untyped sql) -> nil

      # Receive a native adapter result object and returns an ActiveRecord::Result object.
      def cast_result: (untyped raw_result) -> untyped

      def affected_rows: (untyped raw_result) -> untyped

      def preprocess_query: (untyped sql) -> untyped

      # Same as #internal_exec_query, but yields a native adapter result
      def internal_execute: (untyped sql, ?::String name, ?untyped binds, ?prepare: bool, ?async: bool, ?allow_retry: bool, ?materialize_transactions: bool) { (?) -> untyped } -> untyped

      def execute_batch: (untyped statements, ?untyped? name, **untyped kwargs) -> untyped

      def build_fixture_sql: (untyped fixtures, untyped table_name) -> untyped

      def build_fixture_statements: (untyped fixture_set) -> untyped

      def build_truncate_statement: (untyped table_name) -> ::String

      def build_truncate_statements: (untyped table_names) -> untyped

      def combine_multi_statements: (untyped total_sql) -> untyped

      # Returns an ActiveRecord::Result instance.
      def select: (untyped sql, ?untyped? name, ?untyped binds, ?prepare: bool, ?async: bool, ?allow_retry: bool) -> untyped

      def sql_for_insert: (untyped sql, untyped pk, untyped binds, untyped returning) -> ::Array[untyped]

      def last_inserted_id: (untyped result) -> untyped

      def returning_column_values: (untyped result) -> ::Array[untyped]

      def single_value_from_rows: (untyped rows) -> untyped

      def arel_from_relation: (untyped relation) -> untyped

      def extract_table_ref_from_insert_sql: (untyped sql) -> (untyped | nil)
    end
  end
