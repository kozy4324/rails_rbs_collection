      def current_scope: (?bool skip_inherited_scope) -> untyped

      def current_scope=: (untyped scope) -> untyped

      def global_current_scope: (?bool skip_inherited_scope) -> untyped

      def global_current_scope=: (untyped scope) -> untyped

      def scope_registry: () -> untyped
    end

    def populate_with_current_scope_attributes: () -> (nil | untyped)

    def initialize_internals_callback: () -> untyped

    # This class stores the +:current_scope+ and +:ignore_default_scope+ values
    # for different classes. The registry is stored as either a thread or fiber
    # local depending on the application configuration.
    #
    # This class allows you to store and get the scope values on different
    # classes and different types of scopes. For example, if you are attempting
    # to get the current_scope for the +Board+ model, then you would use the
    # following code:
    #
    #   registry = ActiveRecord::Scoping::ScopeRegistry
    #   registry.set_current_scope(Board, some_new_scope)
