    #     config.active_record.shard_resolver = ->(request) {
    #       subdomain = request.subdomain
    #       tenant = Tenant.find_by_subdomain!(subdomain)
    #       tenant.shard
    #     }
    #   end
    #
    # == Configuration
    #
    # The behavior of ShardSelector can be altered through some configuration options.
    #
    # [+lock:+]
