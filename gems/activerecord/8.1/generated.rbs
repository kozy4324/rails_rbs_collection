    module PostgreSQL
      module DatabaseStatements
        @notice_receiver_sql_warnings: untyped

        def explain: (untyped arel, ?untyped binds, ?untyped options) -> untyped

        # Queries the database and returns the results in an Array-like object
        def query: (untyped sql, ?untyped? name, ?allow_retry: bool, ?materialize_transactions: bool) -> untyped

        READ_QUERY: untyped

        def write_query?: (untyped sql) -> untyped

        # Executes an SQL statement, returning a PG::Result object on success
        # or raising a PG::Error exception otherwise.
        #
        # Setting +allow_retry+ to true causes the db to reconnect and retry
        # executing the SQL statement in case of a connection-related exception.
        # This option should only be enabled for known idempotent queries.
        #
        # Note: the PG::Result object is manually memory managed; if you don't
        # need it specifically, you may want consider the <tt>exec_query</tt> wrapper.
        def execute: (*untyped, **untyped) ?{ (?) -> untyped } -> untyped

        def exec_insert: (untyped sql, ?untyped? name, ?untyped binds, ?untyped? pk, ?untyped? sequence_name, ?returning: untyped?) -> untyped

        # Begins a transaction.
        def begin_db_transaction: () -> untyped

        def begin_isolated_db_transaction: (untyped isolation) -> untyped

        # Commits a transaction.
        def commit_db_transaction: () -> untyped

        # Aborts a transaction.
        def exec_rollback_db_transaction: () -> untyped

        def exec_restart_db_transaction: () -> untyped

        # From https://www.postgresql.org/docs/current/functions-datetime.html#FUNCTIONS-DATETIME-CURRENT
        HIGH_PRECISION_CURRENT_TIMESTAMP: untyped

        def high_precision_current_timestamp: () -> untyped

        def build_explain_clause: (?untyped options) -> ("EXPLAIN" | ::String)

        # Set when constraints will be checked for the current transaction.
        #
        # Not passing any specific constraint names will set the value for all deferrable constraints.
        #
        # [<tt>deferred</tt>]
        #   Valid values are +:deferred+ or +:immediate+.
        #
        # See https://www.postgresql.org/docs/current/sql-set-constraints.html
        def set_constraints: (untyped deferred, *untyped constraints) -> untyped

        private

        IDLE_TRANSACTION_STATUSES: ::Array[untyped]

        def cancel_any_running_query: () -> untyped

        def perform_query: (untyped raw_connection, untyped sql, untyped binds, untyped type_casted_binds, prepare: untyped, notification_payload: untyped, ?batch: bool) -> untyped

        def cast_result: (untyped result) -> untyped

        def affected_rows: (untyped result) -> untyped

        def execute_batch: (untyped statements, ?untyped? name, **untyped kwargs) -> untyped

        def build_truncate_statements: (untyped table_names) -> ::Array[::String]

        # Returns the current ID of a table's sequence.
        def last_insert_id_result: (untyped sequence_name) -> untyped

        def returning_column_values: (untyped result) -> untyped

        def suppress_composite_primary_key: (untyped pk) -> (untyped | nil)

        def handle_warnings: (untyped result, untyped sql) -> untyped

        def warning_ignored?: (untyped warning) -> untyped
      end
    end
  end
